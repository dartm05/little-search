# Environment Configuration Template
# Copy this file to .env and update values as needed

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# API CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ============================================
# QDRANT CONFIGURATION
# ============================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents
QDRANT_DISTANCE_METRIC=Cosine

# Collection Settings
QDRANT_VECTOR_SIZE=384
QDRANT_SHARD_NUMBER=1
QDRANT_REPLICATION_FACTOR=1

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# Task Settings
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_DEFAULT_RETRY_DELAY=60

# Worker Settings
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# ============================================
# EMBEDDING CONFIGURATION
# ============================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_LENGTH=512
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=/app/cache/models

# Alternative Models:
# - sentence-transformers/all-mpnet-base-v2 (768 dim, more accurate, slower)
# - sentence-transformers/paraphrase-MiniLM-L3-v2 (384 dim, faster)
# - intfloat/e5-small-v2 (384 dim, good balance)

# ============================================
# DOCUMENT PROCESSING
# ============================================
# Chunking Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_CHUNK_SIZE=2048
MIN_CHUNK_SIZE=128

# Document Limits
MAX_DOCUMENT_SIZE_MB=10
MAX_BATCH_SIZE=100
MAX_DOCUMENTS_PER_USER=10000

# ============================================
# SEARCH CONFIGURATION
# ============================================
DEFAULT_TOP_K=10
MAX_TOP_K=50
MIN_SIMILARITY_SCORE=0.0
SEARCH_TIMEOUT_SECONDS=30

# Cache Settings
ENABLE_SEARCH_CACHE=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=500

# ============================================
# LLM CONFIGURATION (Optional)
# ============================================
# Ollama Settings
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=30

# OpenAI Settings
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# Summary Settings
SUMMARIZATION_MAX_CONTEXT_LENGTH=2000
SUMMARIZATION_MAX_RESULTS=5

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SEARCH_PER_MINUTE=100
RATE_LIMIT_UPLOAD_PER_MINUTE=10
RATE_LIMIT_STORAGE_URI=redis://redis:6379/2

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Flower (Celery Monitoring)
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:password

# Prometheus
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Sentry
SENTRY_ENABLED=false
SENTRY_DSN=

# ============================================
# SECURITY
# ============================================
# API Keys
API_KEY_ENABLED=false
API_KEY_HEADER=X-API-Key
API_KEYS=

# JWT Settings
JWT_ENABLED=false
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# DATABASE (Optional - for metadata)
# ============================================
POSTGRES_ENABLED=false
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=littlesearch
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================
# STORAGE (Optional - for file uploads)
# ============================================
STORAGE_TYPE=local
STORAGE_PATH=/app/storage

# S3 Settings
S3_ENABLED=false
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_ENABLE_ANALYTICS=false
VITE_MAX_FILE_SIZE_MB=10

# ============================================
# DEVELOPMENT TOOLS
# ============================================
# Hot Reload
WATCHFILES_FORCE_POLLING=false

# Debugging
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Testing
TEST_DATABASE_URL=sqlite:///./test.db
PYTEST_TIMEOUT=300
